#include <bits/stdc++.h>
using namespace std;

int main() {
    int t, i;
    cin >> t;
    while(t--){
        int n;
        cin >> n;
        long long a[n];
        long long sum = 0;
        for(i = 0; i < n; i++){
            cin >> a[i];
            sum += a[i];
        }
        cout << sum << endl;

    }
    return 0;
}
